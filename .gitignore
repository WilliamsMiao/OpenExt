# ─── 敏感信息 ─────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── OpenClaw 运行时数据（含鉴权 token、SQLite 数据库） ──────────────────────
.openclaw/

# ─── Agent 运行时 workspace（嵌套 .git 仓库 + OpenClaw 状态文件） ────────────
# 只保留各 Agent 的 identity.md，运行时状态不纳入版本管理
agents/*/workspace/

# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Next.js 构建产物 ─────────────────────────────────────────────────────────
.next/
out/

# ─── 系统文件 ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── Claude Code 会话文件 ─────────────────────────────────────────────────────
.claude/

# ─── 不相关的子项目 ───────────────────────────────────────────────────────────
external-trade-team/
